   RowBox[{"Off", "[", 
    RowBox[{"General", "::", "stop"}], "]"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xBL", "=", 
   RowBox[{"{", 
    RowBox[{"t", ",", "rb", ",", "vartheta", ",", "varphi"}], "}"}]}], 
  ";"}], "\n", 
 RowBox[{
