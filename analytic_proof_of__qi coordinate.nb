  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mbarj", "=", 
   RowBox[{"Sqrt", "[", 
    RowBox[{
     RowBox[{"m", "^", "2"}], "-", 
     RowBox[{"j", "^", "2"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"rbOfR", "=", 
    RowBox[{"r", "+", "m", "+", 
     RowBox[{
      RowBox[{"mbarj", "^", "2"}], "/", 
