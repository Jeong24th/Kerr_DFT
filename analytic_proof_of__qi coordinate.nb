Cell[CellGroupData[{
Cell["\<\
Verification of metric, B-field and dilaton in Quasi-isotropic coordinate\
\>", "Section",
 CellChangeTimes->{{3.9881764085858364`*^9, 3.9881764108493423`*^9}, {
  3.9881764939379025`*^9, 
  3.988176521639168*^9}},ExpressionUUID->"33dc6566-d677-6543-91f1-\
99252f11ba59"],

Cell["\<\
To verify if the solutions (4)-(6) in quasi-isotropic coordinates are \
correct, we show that the solutions in BL coordinates (SM 5)-(SM 7) are \
correct, and that the pull back between them is correct.\
\>", "Text",
 CellChangeTimes->{3.9881767072951527`*^9, 
  3.9881783122602654`*^9},ExpressionUUID->"d4e2493f-6288-6f4b-abed-\
60e3da59a36e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"$Assumptions", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"m", ">", "0"}], ",", 
     RowBox[{"0", "<=", "j", "<", "m"}], ",", 
     RowBox[{"q", ">", "0"}], ",", 
     RowBox[{"r", ">", 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"m", "^", "2"}], "-", 
         RowBox[{"j", "^", "2"}]}], "]"}], "/", "2"}]}], ",", 
     RowBox[{"rb", ">", 
      RowBox[{"m", "+", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"m", "^", "2"}], "-", 
         RowBox[{"j", "^", "2"}]}], "]"}]}]}], ",", 
     RowBox[{"0", "<", "vartheta", "<", "Pi"}], ",", 
     RowBox[{"zeta", "\[Element]", "Reals"}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"$MaxExtraPrecision", "=", "1000"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Off", "[", 
    RowBox[{"N", "::", "meprec"}], "]"}], ";", 
   RowBox[{"Off", "[", 
