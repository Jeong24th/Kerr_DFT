                  RowBox[{"coords", "[", 
                   RowBox[{"[", "d", "]"}], "]"}]}], "]"}]}], ")"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"d", ",", "nDim"}], "}"}]}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"a", ",", "nDim"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"b", ",", "nDim"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"c", ",", "nDim"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Rie", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
