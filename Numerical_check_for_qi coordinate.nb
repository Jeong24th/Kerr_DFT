Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"computeAll", "[", 
     RowBox[{"MM_", ",", "jj_", ",", "QQs_", ",", "zz_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "g", ",", "Bmn", ",", "phi", ",", "ginv", ",", "sqrtmg", ",", "Hflux", 
        ",", "Chr", ",", "Rie", ",", "Ric", ",", "RicScalar", ",", "Hup", ",",
         "HsqMN", ",", "Hsq", ",", "dphi", ",", "HessPhi", ",", "BoxPhi", ",",
         "KinPhi", ",", "Eq1", ",", "Eq2", ",", "Eq3", ",", "RieDown", ",", 
        "RieUp", ",", "Kret"}], "}"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"g", ",", "Bmn", ",", "phi"}], "}"}], "=", 
        RowBox[{"buildFields", "[", 
         RowBox[{"m", ",", "j", ",", "q", ",", "zeta"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"ginv", "=", 
        RowBox[{"Inverse", "[", "g", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"sqrtmg", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"-", 
          RowBox[{"Det", "[", "g", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Hflux", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"D", "[", 
