           RowBox[{"c", ",", "nDim"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Chr", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "/", "2"}], ")"}], " ", 
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"ginv", "[", 
               RowBox[{"[", 
                RowBox[{"a", ",", "d"}], "]"}], "]"}], " ", 
