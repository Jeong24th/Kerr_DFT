             RowBox[{"Bmn", "[", 
              RowBox[{"[", 
               RowBox[{"b", ",", "c"}], "]"}], "]"}], ",", 
             RowBox[{"coords", "[", 
              RowBox[{"[", "a", "]"}], "]"}]}], "]"}], "+", 
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"Bmn", "[", 
              RowBox[{"[", 
               RowBox[{"c", ",", "a"}], "]"}], "]"}], ",", 
             RowBox[{"coords", "[", 
