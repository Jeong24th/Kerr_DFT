      RowBox[{"dphidr", "=", 
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{"phi", ",", "r"}], "]"}], "/", "drdrb"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"hAx", "=", 
       RowBox[{
        RowBox[{"-", "2"}], " ", "q", " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"2", " ", "zeta"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"val", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", " ", "DeltaR", " ", "dphidr"}], ")"}], "^", "2"}], "+", 
        RowBox[{
         RowBox[{"hAx", "^", "2"}], " ", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "4"}], " ", "phi"}], "]"}]}], "-", 
        RowBox[{"4", " ", 
         RowBox[{"q", "^", "2"}]}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Quiet", "[", 
       RowBox[{"Chop", "[", 
        RowBox[{
         RowBox[{"N", "[", 
          RowBox[{
           RowBox[{"val", "/.", " ", "pt"}], ",", "prec"}], "]"}], ",", 
         RowBox[{"10", "^", 
          RowBox[{"(", 
           RowBox[{"-", "prec"}], ")"}]}]}], "]"}], "]"}]}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", "\"\<\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", "\"\<====== First integral (SM 14) ======\>\"", "]"}], 
