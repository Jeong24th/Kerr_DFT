Cell[BoxData[{
 RowBox[{
  RowBox[{"coords", "=", 
   RowBox[{"{", 
    RowBox[{"t", ",", "r", ",", "th", ",", "ph"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"nDim", "=", "4"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"buildFields", "[", 
    RowBox[{"MM_", ",", "jj_", ",", "QQs_", ",", "zz_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "mbarj", ",", "rBL", ",", "sqDelta", ",", "DeltaR", ",", "rho2", ",", 
       "Afac", ",", "Cfac", ",", "omega", ",", "calB", ",", "e2phi", ",", 
       "phi", ",", "g", ",", "Bmn", ",", "hAx"}], "}"}], ",", 
     RowBox[{
      RowBox[{"mbarj", "=", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"m", "^", "2"}], "-", 
         RowBox[{"j", "^", "2"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"rBL", "=", 
       RowBox[{"r", "+", "m", "+", 
        RowBox[{
         RowBox[{"mbarj", "^", "2"}], "/", 
         RowBox[{"(", 
          RowBox[{"4", " ", "r"}], ")"}]}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"sqDelta", "=", 
       RowBox[{"r", "-", 
        RowBox[{
         RowBox[{"mbarj", "^", "2"}], "/", 
         RowBox[{"(", 
          RowBox[{"4", " ", "r"}], ")"}]}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"DeltaR", "=", 
       RowBox[{"sqDelta", "^", "2"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"rho2", "=", 
       RowBox[{
        RowBox[{"rBL", "^", "2"}], "+", 
        RowBox[{
         RowBox[{"j", "^", "2"}], " ", 
         RowBox[{
          RowBox[{"Cos", "[", "th", "]"}], "^", "2"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Afac", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"DeltaR", "-", 
          RowBox[{
           RowBox[{"j", "^", "2"}], " ", 
           RowBox[{
            RowBox[{"Sin", "[", "th", "]"}], "^", "2"}]}]}], ")"}], "/", 
        "rho2"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Cfac", "=", 
       RowBox[{"rho2", " ", "DeltaR", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Sin", "[", "th", "]"}], "^", "2"}], "/", 
         RowBox[{"(", 
          RowBox[{"DeltaR", "-", 
           RowBox[{
            RowBox[{"j", "^", "2"}], " ", 
            RowBox[{
             RowBox[{"Sin", "[", "th", "]"}], "^", "2"}]}]}], ")"}]}]}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"omega", "=", 
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"2", " ", "m", " ", "j", " ", "rBL", " ", 
            RowBox[{
             RowBox[{"Sin", "[", "th", "]"}], "^", "2"}]}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"DeltaR", "-", 
            RowBox[{
             RowBox[{"j", "^", "2"}], " ", 
             RowBox[{
              RowBox[{"Sin", "[", "th", "]"}], "^", "2"}]}]}], ")"}]}], 
         ")"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"calB", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"rho2", "/", 
          RowBox[{"r", "^", "2"}]}], ")"}], " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{
            RowBox[{"mbarj", "^", "2"}], " ", 
            RowBox[{
             RowBox[{
              RowBox[{"Sin", "[", "th", "]"}], "^", "2"}], "/", 
             "DeltaR"}]}]}], ")"}], "^", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"q", "^", "2"}]}], "/", 
           RowBox[{"mbarj", "^", "2"}]}], ")"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"e2phi", "=", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", " ", "r"}], "-", "mbarj"}], ")"}], "/", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", " ", "r"}], "+", "mbarj"}], ")"}]}], ")"}], "^", 
          RowBox[{"(", 
           RowBox[{"2", " ", 
            RowBox[{"q", "/", "mbarj"}]}], ")"}]}], " ", 
         RowBox[{
          RowBox[{"Cos", "[", "zeta", "]"}], "^", "2"}]}], "+", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", " ", "r"}], "+", "mbarj"}], ")"}], "/", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", " ", "r"}], "-", "mbarj"}], ")"}]}], ")"}], "^", 
          RowBox[{"(", 
           RowBox[{"2", " ", 
            RowBox[{"q", "/", "mbarj"}]}], ")"}]}], " ", 
         RowBox[{
          RowBox[{"Sin", "[", "zeta", "]"}], "^", "2"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"phi", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "/", "2"}], ")"}], " ", 
        RowBox[{"Log", "[", "e2phi", "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"g", "=", 
       RowBox[{"ConstantArray", "[", 
        RowBox[{"0", ",", 
         RowBox[{"{", 
          RowBox[{"nDim", ",", "nDim"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"g", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1"}], "]"}], "]"}], "=", 
       RowBox[{
        RowBox[{"-", "e2phi"}], " ", "Afac"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"g", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "4"}], "]"}], "]"}], "=", 
       RowBox[{"e2phi", " ", "Afac", " ", "omega"}]}], ";", 
      RowBox[{
       RowBox[{"g", "[", 
        RowBox[{"[", 
         RowBox[{"4", ",", "1"}], "]"}], "]"}], "=", 
       RowBox[{"g", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "4"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"g", "[", 
        RowBox[{"[", 
         RowBox[{"4", ",", "4"}], "]"}], "]"}], "=", 
       RowBox[{"e2phi", " ", 
        RowBox[{"(", 
         RowBox[{"Cfac", "-", 
          RowBox[{"Afac", " ", 
           RowBox[{"omega", "^", "2"}]}]}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"g", "[", 
        RowBox[{"[", 
         RowBox[{"2", ",", "2"}], "]"}], "]"}], "=", 
       RowBox[{"e2phi", " ", "calB"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"g", "[", 
        RowBox[{"[", 
         RowBox[{"3", ",", "3"}], "]"}], "]"}], "=", 
       RowBox[{"e2phi", " ", "calB", " ", 
        RowBox[{"r", "^", "2"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"hAx", "=", 
       RowBox[{
        RowBox[{"-", "2"}], " ", "q", " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"2", " ", "zeta"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Bmn", "=", 
       RowBox[{"ConstantArray", "[", 
        RowBox[{"0", ",", 
         RowBox[{"{", 
          RowBox[{"nDim", ",", "nDim"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Bmn", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "4"}], "]"}], "]"}], "=", 
       RowBox[{"hAx", " ", 
        RowBox[{"Cos", "[", "th", "]"}]}]}], ";", 
      RowBox[{
       RowBox[{"Bmn", "[", 
        RowBox[{"[", 
         RowBox[{"4", ",", "1"}], "]"}], "]"}], "=", 
       RowBox[{"-", 
        RowBox[{"Bmn", "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", "4"}], "]"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"g", ",", "Bmn", ",", "phi"}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.9874722818729*^9, 3.987472282799244*^9}, 
   3.987472452843767*^9},
